{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1",
      "check": true
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/frontend/dist/index.html",
      "permanent": false
    }
  ]
}
